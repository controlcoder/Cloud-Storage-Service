# =========================
# Application Configuration
# =========================

PORT=5000

# Frontend URL used for CORS configuration
CLIENT_URL=http://localhost:5173


# =========================
# Authentication
# =========================

# Used to verify Google OAuth ID tokens
GOOGLE_CLIENT_ID=

# Used to sign and verify session cookies
SESSION_SECRET=your-session-secret


# =========================
# Email Service (Resend)
# =========================

# API key used for OTP email delivery
# RESEND_API_KEY=


# =========================
# Database
# =========================

# MongoDB connection string
DB_URL=mongodb://localhost:27017/storage-app


# =========================
# Redis
# =========================

# Redis connection URL
REDIS_URL=redis://localhost:6379


# =========================
# AWS S3 Configuration
# =========================

# IAM access key
S3_ACCESS_KEY=

# IAM secret key
S3_SECRET_ACCESS_KEY=

# Bucket region
S3_REGION=ap-south-1

# Bucket name used for file storage
S3_BUCKET_NAME=